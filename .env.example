# =============================================================================
# LIVE PRICES / NEW CARS / FEATURE UPDATES (dynamic data)
# =============================================================================
# This app does NOT scrape dealer websites. It loads ONE JSON file in the
# same shape as public/data/cars.json (brands + cars with variants, prices, features).
#
# 1) Host that JSON somewhere HTTPS (S3, Supabase Storage, GitHub raw, your API).
# 2) Whenever YOUR pipeline updates the file (prices, new models, features),
#    bump "lastUpdated" and/or "version" at the top of the JSON.
# 3) Set CAR_DATA_JSON_URL on the server (Vercel env, Docker, etc.) to that URL.
#
# Then: each visit / tab focus / poll pulls the latest file — new cars & prices appear.
# Without this URL, users only see whatever was baked in at last deploy.
CAR_DATA_JSON_URL=

# Client: poll for changes every N ms (minimum 60000). 0 = no polling.
# Example: 600000 = every 10 minutes while the tab is open.
NEXT_PUBLIC_CAR_DATA_POLL_MS=0

# Client: hide "Refresh prices" with false (shown by default).
# NEXT_PUBLIC_SHOW_CAR_DATA_REFRESH_BUTTON=false

# --- OpenAI (experimental car detail "market check") ---
# Put the real value only in .env.local (gitignored). This file is committed as a template.
OPENAI_API_KEY=
# Optional override (default gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# --- Optional: smarter image pick when running npm run fetch:car-images ---
# Without a key, the script uses title heuristics only. Same OPENAI_API_KEY as above works.

# --- Optional: CarDekho image downloader (scripts/download-cardekho-filter-images.ts) ---
# PLAYWRIGHT_CHANNEL=chrome
# CARDEKHO_FILTER_URL=https://www.cardekho.com/filter/new-cars

# --- Optional: Python scrapers (scripts/python/README.md) ---
# Same PLAYWRIGHT_CHANNEL / CARDEKHO_FILTER_URL apply to:
#   py -3 scripts/python/scrape_india_listings.py cardekho
#   py -3 scripts/python/scrape_india_listings.py carwale
# npm: npm run scrape:india:py -- cardekho

# --- Missing hero images (placeholder cars with cardekhoModelKey) ---
# PLAYWRIGHT_CHANNEL=chrome  npm run download:missing-car-images
# npm run download:missing-car-images -- --max-cars=40 --dry-run

# --- Full local data refresh (scrape + merge + catalogs) ---
# npm run refresh:data        → expand cars.json (missing models) + merge + rebuild catalogs
# npm run refresh:data:full   → scrape ~289 models + expand + merge + catalogs (15–25+ min)
# Use PLAYWRIGHT_CHANNEL=chrome (or msedge) when bundled Chromium fails TLS.

